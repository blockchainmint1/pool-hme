{
  "name": "yiimp-api",
  "version": "0.4.0",
  "private": true,
  "description": "Read-only JSON API in front of the yiimpfrontend MySQL database. Ships pool-native, merged-mining, realtime SSE, and miner endpoints.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p .",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "fastify": "^4.28.1",
    "@fastify/cors": "^9.0.1",
    "fastify-sse-v2": "^4.1.0",
    "mysql2": "^3.11.3",
    "geoip-lite": "^1.4.10"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "tsx": "^4.19.0",
    "@types/node": "^20.14.10",
    "@types/geoip-lite": "^1.4.4"
  }
}
