# Copy to /etc/yiimp-api/env on the yiimp box, chmod 600.
YIIMP_API_PORT=8787
YIIMP_API_BIND=127.0.0.1

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=yiimpfrontend
MYSQL_USER=yiimp_ro
MYSQL_PASSWORD=REPLACE_ME

# Optional: enables /api/pool/stats to scrape stratum summary diag lines
STRATUM_LOG_DIR=/var/stratum

# Front-end origin(s), comma-separated. * = allow all (fine for public read-only).
CORS_ORIGIN=https://pool.honest.money,https://pool-hme.lovable.app
